{
  "format_version": "1.26.0",

  "minecraft:entity": {

    "description": {
      "identifier": "x:wish",
      "is_spawnable": true,
      "is_summonable": true
    },

    "component_groups": {
      "x:despawn": { "minecraft:instant_despawn": {} }
    },

    "components": {
      "minecraft:type_family": { "family": [ "x", "x:temp", "x:wish" ] },
      "minecraft:health": { "value": 1, "min": 1 },
      "minecraft:breathable": { "breathes_air": true, "breathes_water": true, "breathes_lava": true, "breathes_solids": true },
      "minecraft:physics": { "has_collision": false, "has_gravity": false },
      "minecraft:damage_sensor": { "triggers": [ { "cause": "all", "deals_damage": "no" } ] },
      "minecraft:collision_box": { "height": 0.00001, "width": 0.00001 },
      "minecraft:custom_hit_test": { "hitboxes": [ { "width": 0.5, "height": 0.5 } ] },
      "minecraft:knockback_resistance": { "value": 1, "max": 1 },
      "minecraft:despawn": { "despawn_from_distance": {} }      
    },
    
    "events": {
      "x:despawn": { "add": { "component_groups": [ "x:despawn" ] } }
    }
  }
}

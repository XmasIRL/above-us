{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "xmas_above:wish_block_place",
      "materials": {
        "default": "wish_animated"
      },
      "textures": {
        "default": "textures/entity/wish_block_place/default"
      },
      "geometry": {
        "default": "geometry.wish_block"
      },
      // "animations": {
      //   "item": "animation.xmas_above.wish_block.item"
      // },
      // "scripts": {
      //   "animate": [
      //     "item"
      //   ]
      // },
      "scripts": {
        "initialize": [
          "v.fps = 8;",
          "v.die_face = 0;",
          "v.life_time_integer = 0;"
        ],
        "pre_animation": [
          "v.if_roll = v.life_time_integer < math.floor(q.life_time * v.fps);",
          "v.if_roll ? { v.die_face = math.random_integer(0,5); v.life_time_integer = math.floor(q.life_time * v.fps); };"
        ]
      },
      "render_controllers": [
        "controller.render.xmas_above.wish_block"
      ]
    }
  }
}